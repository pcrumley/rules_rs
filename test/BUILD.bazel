    "3rd_party",
    "pyo3",
    "prost",
    "wasm_bindgen",
    # A consumer bzlmod module, not a hub workspace: it has no `@…//:_workspace_deps`
    # target, so it must be excluded from the :all_builds aggregation below.
    "shared_hub_child",
    #"binaries",
    #"build_script_aliases",
    #"build_script_env_select",
    #"build_script_runtime_env",
    #"build_dep_features",
    #"feature_name_overrides_implicit_dep",
    #"many_workspace_deps",
    #"multiple_versions_for_dependency",
    #"multiple_versions_of_optional_dep",
    #"non_optional_dep_feature",
    #"optional_build_deps",
    #"platform_dep_features",
    #"git_crates",
    #"uv",
]

# Tests whose `_workspace_deps` aggregation intentionally fails analysis.
# Their binaries are referenced explicitly in :all_builds below.
BINARY_ONLY_TESTS = ["binary_only"]

TESTS = [f for f in glob(
    ["*"],
    exclude_directories = 0,
) if "." not in f and "bazel-" not in f and f not in DISABLED and f not in BINARY_ONLY_TESTS]

