# Sharing one `@crates`-style hub across two bzlmod modules: the consumer module
# `@shared_hub_child` uses `crate.use_hub` to share this module's `@shared_hub`,
# so both link a single `log` rlib (one global logger). Asserts at runtime that
# a record emitted by the consumer module reaches the logger installed here.
rust_test(
    name = "shared_hub_sharing_test",
    srcs = ["shared_hub_test.rs"],
    edition = "2021",
    deps = [
        "//shared_hub/logger",
        "@shared_hub_child//:child",
    ],
)

sh_test(
    name = "dummy_test",
    srcs = ["dummy_test.sh"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

cc_library(
    name = "rustdoc_musl_unwind_cc",
    srcs = ["rustdoc_musl_unwind.cc"],
)

rust_library(
    name = "rustdoc_musl_unwind",
    srcs = ["rustdoc_musl_unwind.rs"],
    crate_name = "rustdoc_musl_unwind",
    edition = "2021",
    deps = [":rustdoc_musl_unwind_cc"],
)

rust_doc_test(
    name = "rustdoc_musl_unwind_doctest",
    crate = ":rustdoc_musl_unwind",
    tags = ["manual"],
)

rustdoc_musl_unwind_link_flags_test(
    name = "rustdoc_musl_unwind_link_flags_test",
    target_under_test = ":rustdoc_musl_unwind_doctest",
)

